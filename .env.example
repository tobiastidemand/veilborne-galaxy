# Copy to .env.local and fill in to make the shared campaign deploy-ready.
# With none of these set, the API stays open and uses a local .data/ JSON file
# (fine for local play or a single self-hosted instance).

# Require a secret token for writes. The DM appends ?key=<this value> to the URL
# once (it's then remembered on that device). Leave unset to allow open writes.
DM_TOKEN=

# Use a hosted Redis/KV store instead of the local file (needed on serverless /
# multi-instance hosts like Vercel). When BOTH are set, the API uses KV.
# Compatible with Vercel KV and Upstash Redis REST credentials.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Realtime space-battle (/battle). Create a Supabase project and paste its
# Project URL + anon key here. Without them, /battle runs as a local preview.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
